{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HtyBox",
  "version": "1.5.0",
  "identifier": "com.htybox.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HtyBox",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "conpty/x64/conpty.dll": "conpty.dll",
      "conpty/x64/OpenConsole.exe": "OpenConsole.exe"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "installMode": "currentUser",
        "languages": ["SimpChinese"]
      },
      "wix": {
        "language": "zh-CN",
        "bannerPath": "installer/banner.bmp",
        "dialogImagePath": "installer/dialog.bmp"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUyREU0RUIyMDdCRkExRTEKUldUaG9iOEhzazdlVXQzZzhHMmJXMzF4cXoyOXByQjRoY21iSngzQjBBeVphSit6dDZ1elFSYlUK",
      "endpoints": [
        "https://github.com/htyashes-crypto/HtyBox/releases/latest/download/latest.json"
      ]
    }
  }
}
